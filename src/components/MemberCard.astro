---
import InlineContent from "./InlineContent.astro";
import type { InlineSegment, PersonLink } from "../data/types";

interface Props {
  title: InlineSegment[];
  statement: InlineSegment[];
  members: PersonLink[];
  fullWidth?: boolean;
  isPartner?: boolean;
}
const { title, statement, members, fullWidth = false, isPartner = false } = Astro.props;
---
<div class={`card ${fullWidth ? 'full-width' : ''}`}>
  <h3>
    <InlineContent segments={title} />
  </h3>
  <p class:list={["statement", { "statement-partner": isPartner }]}>
    <InlineContent segments={statement} />
  </p>
  <div class="member-list">
    {!isPartner && <span class="list-label">Represented by:</span>}
    {members.map(member => (
      <a href={member.url} target="_blank" rel="noopener noreferrer" class="member-tag">{member.name}</a>
    ))}
  </div>
</div>
